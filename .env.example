# Copy to .env for tools that read it; do not commit real secrets.

# Production / Docker (task.settings.production)
SECRET_KEY=generate-a-long-random-string
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
ALLOWED_HOSTS=your-app.onrender.com,.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
# Set to false behind Render TLS if you need to debug redirects (default true)
# SECURE_SSL_REDIRECT=true

# Local development (optional overrides for task.settings)
# ALLOWED_HOSTS=
